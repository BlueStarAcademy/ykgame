generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum RewardType {
  STAR
  COUPON
}

enum CouponType {
  YK_PARTS_DISCOUNT
  EQUIPMENT_RENTAL_DISCOUNT
  /** 필터세트 교환권 — 시즌 드롭 1장 */
  FILTER_SET_EXCHANGE
}

enum EquipmentPart {
  ARM
  BOOM
  BUCKET
  ENGINE
  TRUCK
  TRUCK_CAPACITY
  TRUCK_SPEED
  CRASH_RESPAWN
  HAUL_TRUCK_SPEED
  GRAPPLE_ADHESION
  HILL_ROCK_PICK
  HILL_SAFE_LOAD
}

model User {
  id                   String                 @id @default(cuid())
  loginId              String                 @unique
  email                String                 @unique
  passwordHash         String
  nickname             String?                @unique
  role                 Role                   @default(USER)
  currency             Int                    @default(0)
  /** Lifetime dump XP — never reset by season */
  totalXp              Int                    @default(0)
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  gameScores           GameScore[]
  seasonStats          UserSeasonStats[]
  rewardEvents         RewardEvent[]
  rewardInventoryItems UserRewardInventory[]
  coupons              UserCoupon[]
  equipmentUpgrades    UserEquipmentUpgrade[]
  mails                UserMail[]
}

model GameScore {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  sessionId String?
  score     Int
  stars     Int
  playTime  Int
  monthKey  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, sessionId])
  @@index([gameId, monthKey, score])
  @@index([gameId, monthKey, userId])
  @@index([userId, gameId])
}

model UserSeasonStats {
  id            String   @id @default(cuid())
  userId        String
  gameId        String
  seasonKey     String
  totalScore    Int      @default(0)
  totalStars    Int      @default(0)
  totalPlayTime Int      @default(0)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, seasonKey])
  @@index([gameId, seasonKey, totalScore])
  @@index([userId, gameId, seasonKey])
}

model RewardEvent {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  eventId   String
  result    Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, eventId])
  @@index([userId, createdAt])
}

model UserRewardInventory {
  id        String     @id @default(cuid())
  userId    String
  gameId    String?
  type      RewardType
  amount    Int        @default(0)
  metadata  Json?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
}

model UserCoupon {
  id          String     @id @default(cuid())
  userId      String
  type        CouponType
  discountPct Int
  barcodeCode String     @unique
  /** Season key when issued (e.g. 2026-3). Used for per-season drop quotas. */
  seasonKey   String
  /** true = game dump drop (counts toward season quota); false = mail/admin */
  fromGameDrop Boolean   @default(true)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, type])
  @@index([seasonKey, type, fromGameDrop])
}

model UserEquipmentUpgrade {
  id        String        @id @default(cuid())
  userId    String
  gameId    String        @default("yanmar")
  part      EquipmentPart
  level     Int           @default(0)
  /** Accumulated success-rate bonus after failed attempts (0~1). */
  failBonus Float         @default(0)
  updatedAt DateTime      @updatedAt
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, part])
  @@index([userId, gameId])
}

model UserMail {
  id                String      @id @default(cuid())
  userId            String
  title             String
  body              String?
  currencyAmount    Int         @default(0)
  couponType        CouponType?
  couponDiscountPct Int?
  readAt            DateTime?
  claimedAt         DateTime?
  createdAt         DateTime    @default(now())
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, claimedAt])
}

/** 관리자 전광판 공지 — sortOrder 오름차순으로 순환 표시 */
model TickerNotice {
  id        String   @id @default(cuid())
  message   String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
}

/** 쿠폰·스타 당첨 등 실시간 전광판 이벤트 (최근분만 유지) */
model TickerWinEvent {
  id        String   @id @default(cuid())
  kind      String
  message   String
  nickname  String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
