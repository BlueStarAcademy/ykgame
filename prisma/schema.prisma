generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum RewardType {
  STAR
  COUPON
}

enum CouponType {
  YK_PARTS_DISCOUNT
  EQUIPMENT_RENTAL_DISCOUNT
  /** 필터세트 교환권 — 시즌 드롭 1장 */
  FILTER_SET_EXCHANGE
}

enum EquipmentPart {
  ARM
  BOOM
  BUCKET
  ENGINE
  TRUCK
  TRUCK_CAPACITY
  TRUCK_SPEED
  CRASH_RESPAWN
  HAUL_TRUCK_SPEED
  GRAPPLE_ADHESION
  HILL_ROCK_PICK
}

model User {
  id                   String                 @id @default(cuid())
  loginId              String                 @unique
  email                String                 @unique
  passwordHash         String
  nickname             String?                @unique
  role                 Role                   @default(USER)
  currency             Int                    @default(0)
  /** Lifetime dump XP — never reset by season */
  totalXp              Int                    @default(0)
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  gameScores           GameScore[]
  rewardInventoryItems UserRewardInventory[]
  coupons              UserCoupon[]
  equipmentUpgrades    UserEquipmentUpgrade[]
  mails                UserMail[]
}

model GameScore {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  score     Int
  stars     Int
  playTime  Int
  monthKey  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gameId, monthKey, score])
  @@index([userId, gameId])
}

model UserRewardInventory {
  id        String     @id @default(cuid())
  userId    String
  gameId    String?
  type      RewardType
  amount    Int        @default(0)
  metadata  Json?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
}

model UserCoupon {
  id          String     @id @default(cuid())
  userId      String
  type        CouponType
  discountPct Int
  barcodeCode String     @unique
  /** Season key when issued (e.g. 2026-3). Used for per-season drop quotas. */
  seasonKey   String
  /** true = game dump drop (counts toward season quota); false = mail/admin */
  fromGameDrop Boolean   @default(true)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, type])
  @@index([seasonKey, type, fromGameDrop])
}

model UserEquipmentUpgrade {
  id        String        @id @default(cuid())
  userId    String
  gameId    String        @default("yanmar")
  part      EquipmentPart
  level     Int           @default(0)
  updatedAt DateTime      @updatedAt
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, part])
  @@index([userId, gameId])
}

model UserMail {
  id                String      @id @default(cuid())
  userId            String
  title             String
  body              String?
  currencyAmount    Int         @default(0)
  couponType        CouponType?
  couponDiscountPct Int?
  readAt            DateTime?
  claimedAt         DateTime?
  createdAt         DateTime    @default(now())
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, claimedAt])
}
