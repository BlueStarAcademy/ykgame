generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum RewardType {
  STAR
  COUPON
}

enum CouponType {
  YK_PARTS_DISCOUNT
  EQUIPMENT_RENTAL_DISCOUNT
  /** 필터세트 교환권 — 시즌 드롭 1장 */
  FILTER_SET_EXCHANGE
}

enum InquiryStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum EquipmentPart {
  ARM
  BOOM
  BUCKET
  ENGINE
  TRUCK
  TRUCK_CAPACITY
  TRUCK_SPEED
  CRASH_RESPAWN
  HAUL_TRUCK_SPEED
  GRAPPLE_ADHESION
  HILL_ROCK_PICK
  HILL_SAFE_LOAD
}

enum ChassisModelId {
  SV08_1C
  SV10
  SV11
  ViO12_2A
  ViO17_1
  ViO20_6
  ViO23_6
  ViO25_6A
  ViO35_74
  ViO35_7A_CJR
  ViO55_6A
  ViO80_7
  SV100_7
}

enum GearSlot {
  ARM
  BOOM
  TRACK
  BUCKET
  BREAKER
  GRAPPLE
}

enum ItemGrade {
  NORMAL
  ENHANCED
  PRECISION
  MASTER
}

enum GachaBanner {
  STANDARD
  PREMIUM
}

enum RepairBuffKind {
  NONE
  SMALL
  LARGE
}

model User {
  id                   String                 @id @default(cuid())
  loginId              String                 @unique
  email                String                 @unique
  passwordHash         String
  nickname             String?                @unique
  /** Yanmar profile portrait — ChassisModelId string */
  profileAvatarId      String?
  role                 Role                   @default(USER)
  currency             Int                    @default(0)
  /** Lifetime dump XP — never reset by season */
  totalXp              Int                    @default(0)
  isActive             Boolean                @default(true)
  /** Set when isActive is false — shown to the player on blocked entry */
  sanctionReason       String?
  sanctionedAt         DateTime?
  createdAt            DateTime               @default(now())
  gameScores           GameScore[]
  seasonStats          UserSeasonStats[]
  rewardEvents         RewardEvent[]
  rewardInventoryItems UserRewardInventory[]
  coupons              UserCoupon[]
  equipmentUpgrades    UserEquipmentUpgrade[]
  mails                UserMail[]
  inquiries            CustomerInquiry[]
  chassisLoadouts      UserChassisLoadout[]
  gearItems            GearItem[]
  repairStates         UserRepairState[]
  gachaPullLogs        GachaPullLog[]
  shopBuffs            UserShopBuff[]
  enhanceCores         Int                    @default(0)
  /** Yanmar gear inventory capacity (expandable to GEAR_INVENTORY_MAX). */
  gearInventorySlots   Int                    @default(40)
}

model GameScore {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  sessionId String?
  score     Int
  stars     Int
  playTime  Int
  monthKey  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, sessionId])
  @@index([gameId, monthKey, score])
  @@index([gameId, monthKey, userId])
  @@index([userId, gameId])
}

model UserSeasonStats {
  id            String   @id @default(cuid())
  userId        String
  gameId        String
  seasonKey     String
  totalScore    Int      @default(0)
  totalStars    Int      @default(0)
  totalPlayTime Int      @default(0)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, seasonKey])
  @@index([gameId, seasonKey, totalScore])
  @@index([userId, gameId, seasonKey])
}

model RewardEvent {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  eventId   String
  result    Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, eventId])
  @@index([userId, createdAt])
}

model UserRewardInventory {
  id        String     @id @default(cuid())
  userId    String
  gameId    String?
  type      RewardType
  amount    Int        @default(0)
  metadata  Json?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
}

model UserCoupon {
  id          String     @id @default(cuid())
  userId      String
  type        CouponType
  discountPct Int
  barcodeCode String     @unique
  /** Season key when issued (e.g. 2026-3). Used for per-season drop quotas. */
  seasonKey   String
  /** true = game dump drop (counts toward season quota); false = mail/admin */
  fromGameDrop Boolean   @default(true)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, type])
  @@index([seasonKey, type, fromGameDrop])
}

model UserEquipmentUpgrade {
  id        String        @id @default(cuid())
  userId    String
  gameId    String        @default("yanmar")
  part      EquipmentPart
  level     Int           @default(0)
  /** Accumulated success-rate bonus after failed attempts (0~1). */
  failBonus Float         @default(0)
  updatedAt DateTime      @updatedAt
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, part])
  @@index([userId, gameId])
}

model UserChassisLoadout {
  id               String         @id @default(cuid())
  userId           String
  gameId           String         @default("yanmar")
  activeChassisId  ChassisModelId @default(ViO17_1)
  /** JSON string array of ChassisModelId */
  ownedChassisIds  Json           @default("[\"ViO17_1\"]")
  /** JSON: { strength, agility, stamina, endurance, balance, technique } */
  abilityAlloc     Json           @default("{\"strength\":0,\"agility\":0,\"stamina\":0,\"endurance\":0,\"balance\":0,\"technique\":0}")
  migratedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId, gameId])
}

model GearItem {
  id             String    @id @default(cuid())
  userId         String
  gameId         String    @default("yanmar")
  slot           GearSlot
  grade          ItemGrade
  enhanceLevel   Int       @default(0)
  failBonus      Float     @default(0)
  mainOption     Json
  subOptions     Json
  masterOption   Json?
  nameSnapshot   String
  durability     Float
  durabilityMax  Float
  equippedSlot   GearSlot?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, gameId])
  @@index([userId, gameId, equippedSlot])
}

model UserRepairState {
  id                 String         @id @default(cuid())
  userId             String
  gameId             String         @default("yanmar")
  buffKind           RepairBuffKind @default(NONE)
  buffExpiresAt      DateTime?
  /** @deprecated Use per-fluid freeAvailableAt fields */
  freeRepairAvailableAt DateTime?
  odometerMeters     Float          @default(0)
  engineOilRemaining Float          @default(1)
  engineOilCapacityMult Float       @default(1)
  engineOilFreeAvailableAt DateTime?
  engineOilFilterRemaining Float    @default(1)
  engineOilFilterCapacityMult Float @default(1)
  engineOilFilterFreeAvailableAt DateTime?
  hydraulicOilFilledAt DateTime?
  hydraulicOilCapacityMult Float    @default(1)
  hydraulicOilFreeAvailableAt DateTime?
  hydraulicFilterFilledAt DateTime?
  hydraulicFilterCapacityMult Float @default(1)
  hydraulicFilterFreeAvailableAt DateTime?
  fuelFilterFilledAt DateTime?
  fuelFilterCapacityMult Float      @default(1)
  fuelFilterFreeAvailableAt DateTime?
  gearOilFilledAt    DateTime?
  gearOilCapacityMult Float         @default(1)
  gearOilFreeAvailableAt DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId, gameId])
}

model GachaPullLog {
  id        String      @id @default(cuid())
  userId    String
  gameId    String      @default("yanmar")
  banner    GachaBanner
  count     Int         @default(1)
  results   Json
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([gameId, createdAt])
}

/** Timed shop consumable buffs (server authority for reward APIs). */
model UserShopBuff {
  id        String   @id @default(cuid())
  userId    String
  gameId    String   @default("yanmar")
  itemId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, itemId])
  @@index([userId, gameId, expiresAt])
}

model UserMail {
  id                String      @id @default(cuid())
  userId            String
  title             String
  body              String?
  currencyAmount    Int         @default(0)
  couponType        CouponType?
  couponDiscountPct Int?
  readAt            DateTime?
  claimedAt         DateTime?
  createdAt         DateTime    @default(now())
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, claimedAt])
}

/** 인게임 고객문의 */
model CustomerInquiry {
  id        String         @id @default(cuid())
  userId    String
  title     String
  body      String
  status    InquiryStatus  @default(OPEN)
  adminNote String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
}

/** 관리자 전광판 공지 — sortOrder 오름차순으로 순환 표시 */
model TickerNotice {
  id        String   @id @default(cuid())
  message   String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
}

/** 전광판 전역 설정 (싱글톤 id=default) */
model TickerSettings {
  id            String   @id @default("default")
  /** Scroll speed in pixels per second (20–200). */
  scrollSpeedPx Int      @default(60)
  updatedAt     DateTime @updatedAt
}

/** 쿠폰·스타 당첨 등 실시간 전광판 이벤트 (최근분만 유지) */
model TickerWinEvent {
  id        String   @id @default(cuid())
  kind      String
  message   String
  nickname  String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
