# === Railway 배포 (Variables 탭에 설정) ===
# 런타임 연결 — PgBouncer 도입 후 PgBouncer 서비스 URL Reference로 교체
DATABASE_URL=${{Postgres.DATABASE_URL}}
# migration/pre-deploy 전용 direct 연결 — 항상 Postgres 원본 URL
DIRECT_DATABASE_URL=${{Postgres.DATABASE_URL}}

# 앱 인스턴스별 pg.Pool. 파서는 아래 안전 범위로 clamp합니다.
# max: 5~50, connection timeout: 1000~30000ms, idle timeout: 1000~300000ms
DATABASE_POOL_MAX=20
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000
DATABASE_POOL_IDLE_TIMEOUT_MS=30000

# 예산 예시: Postgres max_connections=100, 운영/관리 reserve=20이면 앱 예산=80.
# replica 4 * DATABASE_POOL_MAX 20 = 80 <= 100 - 20
# PgBouncer transaction pooling에서는 PgBouncer의 DB server pool도 이 예산 안에서 설정합니다.

# Railway Redis 서비스의 private URL Reference. 미설정 시 Redis 기능은 disabled이며
# 랭킹/세션버전은 로컬 TTL, dump rate limit은 제한적 fail-open입니다.
# REDIS_URL이 설정된 환경에서 Redis 장애 시 dump rate limit은 fail-closed(429)입니다.
REDIS_URL=${{Redis.REDIS_URL}}
REDIS_PREFIX=ykgame
# 연결/명령 timeout 및 재연결 횟수는 애플리케이션에서 안전 범위로 clamp됩니다.
REDIS_CONNECT_TIMEOUT_MS=1500
REDIS_COMMAND_TIMEOUT_MS=750
REDIS_RECONNECT_ATTEMPTS=3
# 사용자별 dump token bucket: 요청 수가 아닌 chunk 수를 소비합니다.
DUMP_RATE_LIMIT_CAPACITY=20
DUMP_RATE_LIMIT_REFILL_PER_SEC=5

# 필수 — 아래 한 줄만 직접 입력 (openssl rand -base64 32)
AUTH_SECRET=

# 굴착기 운동회 주간 정산 cron (Authorization: Bearer …)
# Railway Cron Job → GET/POST https://<domain>/api/cron/sports-meet/settle
# 권장 스케줄: 매주 일요일 15:05 UTC (= 월요일 00:05 KST)
# CRON_SECRET=

# AUTH_URL은 Railway 도메인으로 자동 설정됩니다 (RAILWAY_PUBLIC_DOMAIN)
# 커스텀 도메인 사용 시에만 수동 설정:
# AUTH_URL=https://your-domain.com

# === 로컬 개발 (.env 파일에 설정) ===
# DATABASE_PUBLIC_URL="postgresql://...@xxx.proxy.rlwy.net:PORT/railway"
# DATABASE_URL="postgresql://...@postgres.railway.internal:5432/railway"
# DIRECT_DATABASE_URL="postgresql://...@xxx.proxy.rlwy.net:PORT/railway"
# AUTH_SECRET="local-dev-secret"
# AUTH_URL="http://localhost:3000"

# OAuth (추후 연동)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
